[
  {
    "name": "code_for_me",
    "handle": "code_for_me",
    "mode": "prompt",
    "description": "Prompt-driven repository task run. Omitted or `default` `responseMode` uses bundled `caveman-full`; set `off` for normal prose.",
    "activation": {
      "type": "skill_request",
      "skill": "code_for_me",
      "input": {
        "config": {
          "repos": [
            "<git@github.com:owner/repo.git>"
          ],
          "prompt": "<describe the requested change>",
          "responseMode": "<default|off|caveman-lite|caveman-full|caveman-ultra|caveman-wenyan-lite|caveman-wenyan-full|caveman-wenyan-ultra>",
          "reviewers": [
            "<githubhandle>"
          ],
          "images": []
        }
      }
    }
  },
  {
    "name": "code_review",
    "handle": "code_review",
    "mode": "review",
    "displayName": "Pull Request Code Review",
    "description": "Runs the code-review workflow using repo + either branch or prNumber context. Omitted or `default` `responseMode` uses bundled `caveman-full`; set `off` for normal prose.",
    "activation": {
      "type": "skill_request",
      "skill": "code_review",
      "input": {
        "config": {
          "repos": [
            "<git@github.com:owner/repo.git>"
          ],
          "branch": "<pull-request-head-branch>",
          "responseMode": "<default|off|caveman-lite|caveman-full|caveman-ultra|caveman-wenyan-lite|caveman-wenyan-full|caveman-wenyan-ultra>"
        }
      }
    }
  }
]
